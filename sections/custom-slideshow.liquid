{% comment %}
  custom-slideshow — copies the pattern in sections/custom-hero.liquid.
  Slides are blocks. Reuses Dawn's slider-component (global.js) and
  component-slider.css for the sliding behaviour and controls — commerce
  and core JS stay untouched per CLAUDE.md.
{% endcomment %}

{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #Slideshow-{{ section.id }} .custom-slideshow__slide {
    min-height: {% case section.settings.slide_height %}{% when 'small' %}20rem{% when 'medium' %}26rem{% else %}32rem{% endcase %};
  }

  #Slideshow-{{ section.id }} .custom-slideshow__overlay {
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }

  .custom-slideshow {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    gap: 0;
    margin: 0;
    padding: 0;
    overflow-y: hidden;
  }

  /* Dawn's .slider--everywhere supplies overflow-x + scroll-snap; its smooth
     scroll-behavior is overridden (doubled class beats Dawn's single-class
     rule) because Chrome cancels the smooth programmatic scroll against the
     mandatory snap and the arrows do nothing. */
  .custom-slideshow.slider--everywhere {
    scroll-behavior: auto;
  }

  .custom-slideshow__slide {
    position: relative;
    display: grid;
    place-items: center;
    overflow: hidden;
    width: 100%;
    flex: 0 0 100%;
  }

  .custom-slideshow__image,
  .custom-slideshow__image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .custom-slideshow__overlay {
    position: absolute;
    inset: 0;
    background: #000000;
  }

  .custom-slideshow__content {
    position: relative;
    text-align: center;
    max-width: 60rem;
    padding: 5rem 2rem;
  }

  @media screen and (min-width: 750px) {
    #Slideshow-{{ section.id }} .custom-slideshow__slide {
      min-height: {% case section.settings.slide_height %}{% when 'small' %}28rem{% when 'medium' %}36rem{% else %}45rem{% endcase %};
    }
  }
{%- endstyle -%}

{% # slideshow-component (not bare slider-component): Dawn only ever pairs slider--everywhere with it, and it supplies looping + slide visibility handling. %}
<slideshow-component id="Slideshow-{{ section.id }}" class="color-{{ section.settings.color_scheme }} gradient">
  <ul
    id="Slider-{{ section.id }}"
    class="custom-slideshow slider slider--everywhere"
    role="list"
    aria-label="{{ 'general.slider.name' | t }}"
  >
    {%- for block in section.blocks -%}
      <li
        id="Slide-{{ section.id }}-{{ forloop.index }}"
        class="custom-slideshow__slide slideshow__slide slider__slide"
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.image != blank -%}
          <div class="custom-slideshow__image">
            {% # image_tag output is not piped through escape: the filter builds the tag itself and escapes its own attributes (including alt). %}
            {{
              block.settings.image
              | image_url: width: 3000
              | image_tag: widths: '750, 1100, 1500, 2200, 3000', sizes: '100vw', loading: 'lazy'
            }}
          </div>
          <div class="custom-slideshow__overlay"></div>
        {%- endif -%}

        <div class="custom-slideshow__content">
          {%- if block.settings.heading != blank -%}
            <h2 class="custom-slideshow__heading h1">{{ block.settings.heading | escape }}</h2>
          {%- endif -%}

          {%- if block.settings.cta_label != blank -%}
            <a
              {% if block.settings.cta_link == blank %}
                role="link" aria-disabled="true"
              {% else %}
                href="{{ block.settings.cta_link }}"
              {% endif %}
              class="button button--primary"
            >
              {{- block.settings.cta_label | escape -}}
            </a>
          {%- endif -%}
        </div>
      </li>
    {%- endfor -%}
  </ul>

  {%- if section.blocks.size > 1 -%}
    <div class="slider-buttons">
      <button
        type="button"
        class="slider-button slider-button--prev"
        name="previous"
        aria-label="{{ 'general.slider.previous_slide' | t }}"
        aria-controls="Slider-{{ section.id }}"
      >
        <span class="svg-wrapper">
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </span>
      </button>
      <div class="slider-counter caption">
        <span class="slider-counter--current">1</span>
        <span aria-hidden="true"> / </span>
        <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
        <span class="slider-counter--total">{{ section.blocks.size }}</span>
      </div>
      <button
        type="button"
        class="slider-button slider-button--next"
        name="next"
        aria-label="{{ 'general.slider.next_slide' | t }}"
        aria-controls="Slider-{{ section.id }}"
      >
        <span class="svg-wrapper">
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </span>
      </button>
    </div>
  {%- endif -%}
</slideshow-component>

{% schema %}
{
  "name": "Custom slideshow",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "slide_height",
      "label": "Slide height",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 10,
      "unit": "%",
      "label": "Image overlay opacity",
      "default": 40
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-4"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Image pickers can't have defaults; the color scheme background shows until one is chosen."
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Tell a story slide by slide"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Button label",
          "default": "Shop all"
        },
        {
          "type": "url",
          "id": "cta_link",
          "label": "Button link",
          "default": "/collections/all"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom slideshow",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
