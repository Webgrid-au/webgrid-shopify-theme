{% comment %}
  custom-multicolumn — copies the pattern in sections/custom-hero.liquid.
  Columns are blocks so merchants can add/remove/reorder them in the editor.
{% endcomment %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .custom-multicolumn__heading {
    margin: 0 0 3rem;
  }

  .custom-multicolumn__grid {
    display: grid;
    gap: 3rem 2rem;
  }

  .custom-multicolumn__column-title {
    margin: 0 0 1rem;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .custom-multicolumn__grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    {%- if section.settings.heading != blank -%}
      <h2 class="custom-multicolumn__heading h2">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    <div class="custom-multicolumn__grid">
      {%- for block in section.blocks -%}
        <div class="custom-multicolumn__column" {{ block.shopify_attributes }}>
          {%- if block.settings.title != blank -%}
            <h3 class="custom-multicolumn__column-title h4">{{ block.settings.title | escape }}</h3>
          {%- endif -%}

          {%- if block.settings.text != blank -%}
            {% # Not escaped: richtext setting — the editor emits trusted HTML (<p>, <strong>, links). %}
            <div class="custom-multicolumn__column-text rte">{{ block.settings.text }}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom multicolumn",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why shop with us"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Desktop columns",
      "default": 3
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Column title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Use a few short sentences to make a single point per column.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom multicolumn",
      "blocks": [
        { "type": "column" },
        { "type": "column" },
        { "type": "column" }
      ]
    }
  ]
}
{% endschema %}
