{% comment %}
  custom-image-banner — copies the pattern in sections/custom-hero.liquid.
  Full-bleed image with overlaid content; without an image the color
  scheme background carries the banner, so it works straight from the preset.
{% endcomment %}

{%- style -%}
  #Banner-{{ section.id }} {
    min-height: {% case section.settings.image_height %}{% when 'small' %}20rem{% when 'medium' %}26rem{% else %}32rem{% endcase %};
  }

  #Banner-{{ section.id }} .custom-image-banner__overlay {
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }

  .custom-image-banner {
    position: relative;
    display: grid;
    place-items: center;
    overflow: hidden;
  }

  .custom-image-banner__image,
  .custom-image-banner__image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .custom-image-banner__overlay {
    position: absolute;
    inset: 0;
    background: #000000;
  }

  .custom-image-banner__content {
    position: relative;
    text-align: center;
    max-width: 60rem;
    padding: 5rem 2rem;
  }

  .custom-image-banner__text {
    margin: 1.5rem 0 2rem;
  }

  @media screen and (min-width: 750px) {
    #Banner-{{ section.id }} {
      min-height: {% case section.settings.image_height %}{% when 'small' %}28rem{% when 'medium' %}36rem{% else %}45rem{% endcase %};
    }
  }
{%- endstyle -%}

<div id="Banner-{{ section.id }}" class="custom-image-banner color-{{ section.settings.color_scheme }} gradient">
  {%- if section.settings.image != blank -%}
    <div class="custom-image-banner__image">
      {% # image_tag output is not piped through escape: the filter builds the tag itself and escapes its own attributes (including alt). %}
      {{
        section.settings.image
        | image_url: width: 3000
        | image_tag: widths: '750, 1100, 1500, 2200, 3000', sizes: '100vw'
      }}
    </div>
    <div class="custom-image-banner__overlay"></div>
  {%- endif -%}

  <div class="custom-image-banner__content">
    {%- if section.settings.heading != blank -%}
      <h2 class="custom-image-banner__heading h1">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.settings.text != blank -%}
      {% # Not escaped: richtext setting — the editor emits trusted HTML (<p>, <strong>, links). %}
      <div class="custom-image-banner__text rte">{{ section.settings.text }}</div>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <a
        {% if section.settings.cta_link == blank %}
          role="link" aria-disabled="true"
        {% else %}
          href="{{ section.settings.cta_link }}"
        {% endif %}
        class="button button--primary"
      >
        {{- section.settings.cta_label | escape -}}
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Custom image banner",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Image pickers can't have defaults; the color scheme background shows until one is chosen."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 10,
      "unit": "%",
      "label": "Image overlay opacity",
      "default": 40
    },
    {
      "type": "select",
      "id": "image_height",
      "label": "Banner height",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "large"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Browse our latest products"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Give shoppers one reason to keep scrolling.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop all"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link",
      "default": "/collections/all"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-3"
    }
  ],
  "presets": [
    {
      "name": "Custom image banner"
    }
  ]
}
{% endschema %}
