{% comment %}
  custom-hero — reference pattern for all custom- sections.
  Self-contained: CSS lives in the {% style %} block below, all copy comes
  from schema settings, layout leans on Dawn utility classes (page-width,
  color scheme, button) so global tokens keep working.
{% endcomment %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .custom-hero {
    display: grid;
    gap: 3rem;
    align-items: center;
  }

  .custom-hero__media {
    order: -1;
  }

  .custom-hero__media img,
  .custom-hero__media .placeholder-svg {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--media-radius, 0);
  }

  .custom-hero__intro {
    margin: 1.5rem 0 2rem;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .custom-hero {
      grid-template-columns: 1fr 1fr;
    }

    .custom-hero__media {
      order: 1;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="custom-hero">
      <div class="custom-hero__content">
        {%- if section.settings.heading != blank -%}
          <h2 class="custom-hero__heading h1">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.intro != blank -%}
          {% # Not escaped: richtext setting — the editor emits trusted HTML (<p>, <strong>, links). %}
          <div class="custom-hero__intro rte">{{ section.settings.intro }}</div>
        {%- endif -%}

        {%- if section.settings.cta_label != blank -%}
          <a
            {% if section.settings.cta_link == blank %}
              role="link" aria-disabled="true"
            {% else %}
              href="{{ section.settings.cta_link }}"
            {% endif %}
            class="button button--primary"
          >
            {{- section.settings.cta_label | escape -}}
          </a>
        {%- endif -%}
      </div>

      <div class="custom-hero__media">
        {%- if section.settings.image != blank -%}
          {% # image_tag output is not piped through escape: the filter builds the tag itself and escapes its own attributes (including alt). %}
          {{
            section.settings.image
            | image_url: width: 1500
            | image_tag: widths: '375, 550, 750, 1100, 1500', sizes: '(min-width: 750px) 50vw, 100vw'
          }}
        {%- else -%}
          {% # placeholder_svg_tag emits a static theme SVG, nothing merchant-authored to escape. %}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom hero",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Build something worth shipping"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro text",
      "default": "<p>Introduce the brand in a sentence or two. This copy is fully merchant-editable from the theme editor.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Image pickers can't have defaults; a placeholder renders until one is chosen."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop all"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link",
      "default": "/collections/all"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Custom hero"
    }
  ]
}
{% endschema %}
