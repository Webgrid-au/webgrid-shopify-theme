{% comment %}
  custom-image-with-text — copies the pattern in sections/custom-hero.liquid.
{% endcomment %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .custom-image-with-text {
    display: grid;
    gap: 3rem;
    align-items: center;
  }

  .custom-image-with-text__media img,
  .custom-image-with-text__media .placeholder-svg {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--media-radius, 0);
  }

  .custom-image-with-text__text {
    margin: 1.5rem 0 2rem;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .custom-image-with-text {
      grid-template-columns: 1fr 1fr;
    }

    .custom-image-with-text__media--second {
      order: 1;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="custom-image-with-text">
      <div class="custom-image-with-text__media{% if section.settings.layout == 'image_second' %} custom-image-with-text__media--second{% endif %}">
        {%- if section.settings.image != blank -%}
          {% # image_tag output is not piped through escape: the filter builds the tag itself and escapes its own attributes (including alt). %}
          {{
            section.settings.image
            | image_url: width: 1500
            | image_tag: widths: '375, 550, 750, 1100, 1500', sizes: '(min-width: 750px) 50vw, 100vw'
          }}
        {%- else -%}
          {% # placeholder_svg_tag emits a static theme SVG, nothing merchant-authored to escape. %}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>

      <div class="custom-image-with-text__content">
        {%- if section.settings.heading != blank -%}
          <h2 class="custom-image-with-text__heading h2">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          {% # Not escaped: richtext setting — the editor emits trusted HTML (<p>, <strong>, links). %}
          <div class="custom-image-with-text__text rte">{{ section.settings.text }}</div>
        {%- endif -%}

        {%- if section.settings.link_label != blank -%}
          <a
            {% if section.settings.link == blank %}
              role="link" aria-disabled="true"
            {% else %}
              href="{{ section.settings.link }}"
            {% endif %}
            class="button button--secondary"
          >
            {{- section.settings.link_label | escape -}}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom image with text",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Image pickers can't have defaults; a placeholder renders until one is chosen."
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Desktop image placement",
      "options": [
        { "value": "image_first", "label": "Image first" },
        { "value": "image_second", "label": "Image second" }
      ],
      "default": "image_first"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Pair text with an image"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Focus on a story, a process, or a product detail. Keep it to a short paragraph and let the image carry the weight.</p>"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link",
      "info": "URL defaults only accept a few Shopify paths, so this defaults to the catalog.",
      "default": "/collections/all"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Custom image with text"
    }
  ]
}
{% endschema %}
